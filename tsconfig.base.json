{
	"compilerOptions": {
		"paths": {
			"src/*": ["./src/*"]
		},
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "bundler",
		"strict": true,
		"noImplicitOverride": true,
		"noEmit": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"lib": ["DOM", "ES2020"]
	}
}
