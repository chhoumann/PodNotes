{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"allowJs": true,
		// JavaScript tools opt in with `@ts-check` until the E2E runner scripts are typed.
		"checkJs": false,
		"types": ["svelte", "node", "obsidian", "vitest/globals", "@testing-library/jest-dom"]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.svelte",
		"tests/**/*.ts",
		"tests/**/*.svelte",
		"scripts/**/*.ts",
		"*.ts",
		"*.mjs"
	]
}
