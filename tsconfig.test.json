{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"lib": ["DOM", "ES2021"],
		"types": ["svelte", "node", "obsidian", "vitest/globals", "@testing-library/jest-dom"]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.svelte",
		"tests/**/*.ts",
		"tests/**/*.svelte",
		"scripts/**/*.ts",
		"scripts/**/*.mjs",
		"*.ts",
		"*.mjs"
	]
}
